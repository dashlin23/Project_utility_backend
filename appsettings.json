{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_CONNECTION_STRING"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_SECRET_KEY",
    "Issuer": "PaymentUtility",
    "Audience": "PaymentUtilityUsers",
    "ExpiryInDays": 7
  }
}